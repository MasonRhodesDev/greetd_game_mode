#!/bin/sh
# Mirror the active hyprstate monitor profile to the greeter so the login
# screen inherits the session's monitor layout (rotation/scale/positions).
# Runs as mason via an hyprstate profile hook (--@ hook = greeter-hint-sync);
# /etc/greetd/monitors-hint.lua is pre-created mason:greeter so no sudo is
# needed. The greeter's hypr.lua dofile()s the hint inside pcall — a stale or
# missing hint can never break login.
ACTIVE="$HOME/.config/hypr/profiles/.active.lua"
HINT="/etc/greetd/monitors-hint.lua"
[ -L "$ACTIVE" ] && [ -w "$HINT" ] && cat "$(readlink -f "$ACTIVE")" > "$HINT" 2>/dev/null || true
