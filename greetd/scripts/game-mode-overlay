#!/usr/bin/python3
"""Launcher for discover-overlay with two runtime fixes (upstream 0.7.8):

1. Its Discord RPC websocket connect uses timeout=0.1 — too tight while
   Discord is still starting (port listens before the RPC server answers).
2. Only ConnectionError is caught around the connect, so a
   WebSocketTimeoutException escapes the GLib callback and silently kills
   the retry loop — the overlay process stays alive but never connects.

Patching at runtime keeps the pacman-owned package files untouched.
"""
import websocket

_orig_create = websocket.create_connection


def _create(url, *args, **kwargs):
    kwargs["timeout"] = max(kwargs.get("timeout") or 0, 2.0)
    return _orig_create(url, *args, **kwargs)


websocket.create_connection = _create

from discover_overlay import discord_connector  # noqa: E402

_orig_connect = discord_connector.DiscordConnector.connect


def _safe_connect(self):
    try:
        _orig_connect(self)
    except Exception:  # any connect failure -> retry, never kill the loop
        self.websocket = None
        self.schedule_reconnect()


discord_connector.DiscordConnector.connect = _safe_connect

from discover_overlay.discover_overlay import entrypoint  # noqa: E402

entrypoint()
