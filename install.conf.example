# Per-machine settings for install.sh (shell syntax). Normally you don't
# create this by hand: the first interactive run of install.sh prompts for
# these (defaulting to the invoking user) and writes install.conf itself.
# Pre-create it only for non-interactive installs. install.conf is gitignored.

# The user the game session autologs in as, their group, and the shared game
# library directory (bound read-write into the sandbox).
#GAMES_USER=games
#GAMES_GROUP=games
#GAMES_DIR=/games
