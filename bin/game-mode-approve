#!/bin/bash
# game-mode entry approval. Run by the game-mode daemon (as greeter) when the
# guide button is pressed at the greeter. Creates a request in the verifier
# (which Web-Pushes the phone: tap -> approve page auto-fires passkey ->
# biometric), then polls for the decision. Progress is shown on the greeter
# screen via hyprctl notify (the greeter compositor is Hyprland).
#
# Exit: 0 = approved (enter game mode), non-zero = denied/timeout/unreachable
#       (stay at greeter; fail-closed).
set -u
ENV_FILE="${AG_ENV_FILE:-/etc/game-mode/approval.env}"
# shellcheck disable=SC1090
[ -r "$ENV_FILE" ] && . "$ENV_FILE"
: "${AG_VERIFIER_CTRL:?}" "${AG_APPROVE_BASE:?}" "${AG_TIMEOUT:=90}"

# On-screen banner at the greeter (best-effort). Args: <icon> <ms> <message>
# icons: 0 warning, 1 info, 3 error, 5 ok
notify() {
    local dir sig
    dir="/run/user/$(id -u)/hypr"
    sig=$(ls -t "$dir" 2>/dev/null | head -1)
    [ -n "$sig" ] || return 0
    XDG_RUNTIME_DIR="/run/user/$(id -u)" HYPRLAND_INSTANCE_SIGNATURE="$sig" \
        hyprctl notify "$1" "$2" 0 "$3" >/dev/null 2>&1 || true
}

# 1. create request (localhost control plane). curl failure -> verifier down.
RESP=$(curl -sS --max-time 5 -X POST "$AG_VERIFIER_CTRL/request" \
        -H 'content-type: application/json' \
        -d '{"exe":"game-mode","path":"switch this PC into Steam game mode","group":"login","title":"Enter game mode?"}' 2>/dev/null) \
    || { notify 3 8000 "Game mode: approval service unreachable"; exit 2; }
ID=$(printf '%s' "$RESP" | python3 -c 'import sys,json;print(json.load(sys.stdin).get("id",""))' 2>/dev/null)
[ -n "$ID" ] || { notify 3 8000 "Game mode: approval service unreachable"; exit 2; }
echo "game-mode-approve: request $ID -> ${AG_APPROVE_BASE}/${ID}" >&2
notify 1 "$(( AG_TIMEOUT * 1000 ))" "Approval sent to your phone — confirm with fingerprint"

# 2. poll for the decision (the verifier already pushed the phone)
deadline=$(( $(date +%s) + AG_TIMEOUT ))
while [ "$(date +%s)" -lt "$deadline" ]; do
    R=$(curl -sS --max-time 5 "$AG_VERIFIER_CTRL/result/$ID" 2>/dev/null) \
        || { notify 3 8000 "Game mode: approval service unreachable"; exit 2; }
    case "$(printf '%s' "$R" | python3 -c 'import sys,json;print(json.load(sys.stdin).get("status",""))' 2>/dev/null)" in
        approved)
            echo "game-mode-approve: APPROVED" >&2
            notify 5 3000 "Approved — entering game mode"
            exit 0 ;;
        denied)
            echo "game-mode-approve: DENIED" >&2
            notify 3 6000 "Game mode entry denied"
            exit 1 ;;
        expired|unknown)
            notify 0 6000 "Approval expired — press the Guide button to retry"
            exit 1 ;;
    esac
    sleep 1
done
echo "game-mode-approve: TIMEOUT" >&2
notify 0 6000 "Approval timed out — press the Guide button to retry"
exit 1
